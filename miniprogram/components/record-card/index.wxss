.record-card {
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 16rpx;
  box-shadow: 0 4rpx 24rpx rgba(99, 102, 241, 0.08);
}

.record-card.compact { padding: 16rpx 24rpx; }
.record-card.compact .card-info { gap: 16rpx; }

.card-header {
  margin-bottom: 16rpx;
}

.customer-name {
  font-size: 30rpx;
  font-weight: 700;
  color: var(--gray-800);
}

.product-name {
  font-size: 24rpx;
  color: var(--gray-500);
  margin-top: 4rpx;
}

.card-info {
  display: flex;
  flex-wrap: wrap;
  gap: 24rpx;
  margin-bottom: 16rpx;
}

.info-item {
  display: flex;
  flex-direction: column;
  min-width: 100rpx;
}

.info-label {
  font-size: 22rpx;
  color: var(--gray-400);
  margin-bottom: 2rpx;
}

.info-value {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--gray-700);
}

.card-status {
  display: flex;
  gap: 12rpx;
  flex-wrap: wrap;
  margin-bottom: 16rpx;
}

.card-actions {
  display: flex;
  gap: 12rpx;
  border-top: 1rpx solid var(--gray-100);
  padding-top: 16rpx;
}

.action-btn {
  font-size: 24rpx;
  color: var(--gray-500);
  padding: 6rpx 16rpx;
  border-radius: 8rpx;
  background: var(--gray-50);
}

.action-btn:active { background: var(--gray-100); }
.action-success { color: var(--success); }
.action-info { color: var(--info); }
.action-danger { color: var(--danger); }
