.pagination {
  padding: 24rpx 0;
  text-align: center;
}

.load-more {
  display: inline-block;
  padding: 14rpx 40rpx;
  background: var(--primary-bg);
  color: var(--primary);
  font-size: 26rpx;
  font-weight: 600;
  border-radius: 40rpx;
}

.load-more:active { opacity: 0.7; }

.no-more {
  font-size: 24rpx;
  color: var(--gray-400);
}
