.timeline {
  padding: 16rpx 0;
}

.timeline-item {
  display: flex;
  gap: 20rpx;
  padding-bottom: 32rpx;
  position: relative;
}

.timeline-item:last-child { padding-bottom: 0; }

.timeline-dot-wrap {
  display: flex;
  flex-direction: column;
  align-items: center;
  flex-shrink: 0;
  width: 28rpx;
}

.timeline-dot {
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
  background: var(--gray-300);
  flex-shrink: 0;
  margin-top: 6rpx;
}

.timeline-item.active .timeline-dot {
  width: 22rpx;
  height: 22rpx;
  background: var(--primary);
  box-shadow: 0 0 0 6rpx rgba(99, 102, 241, 0.2);
}

.timeline-line {
  width: 3rpx;
  flex: 1;
  background: var(--gray-200);
  margin-top: 8rpx;
}

.timeline-content {
  flex: 1;
  min-width: 0;
}

.timeline-time {
  font-size: 24rpx;
  color: var(--gray-400);
  margin-bottom: 4rpx;
}

.timeline-item.active .timeline-time {
  color: var(--primary);
  font-weight: 600;
}

.timeline-text {
  font-size: 26rpx;
  color: var(--gray-700);
  line-height: 1.5;
}

.timeline-item.active .timeline-text {
  color: var(--gray-800);
  font-weight: 600;
}

.empty-timeline {
  text-align: center;
  color: var(--gray-400);
  font-size: 26rpx;
  padding: 40rpx;
}
