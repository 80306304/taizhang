.import-page {
  padding: 24rpx 28rpx;
  padding-bottom: calc(env(safe-area-inset-bottom) + 24rpx);
}

.card {
  background: #fff;
  border-radius: 16rpx;
  box-shadow: 0 4rpx 24rpx rgba(99, 102, 241, 0.08);
  padding: 28rpx;
  margin-bottom: 20rpx;
}

.card-title {
  font-size: 28rpx;
  font-weight: 700;
  color: var(--gray-700);
  margin-bottom: 16rpx;
}

.hint {
  font-size: 22rpx;
  color: var(--gray-400);
}
.mb-md { margin-bottom: 20rpx; }

/* Upload Area */
.upload-area {
  border: 3rpx dashed var(--gray-300);
  border-radius: 16rpx;
  padding: 60rpx 40rpx;
  text-align: center;
  transition: border-color 0.2s;
}

.upload-area:active {
  border-color: var(--primary);
}

.upload-icon {
  font-size: 56rpx;
  margin-bottom: 12rpx;
}

.upload-text {
  font-size: 28rpx;
  color: var(--gray-600);
  font-weight: 600;
  margin-bottom: 8rpx;
}

.upload-hint {
  font-size: 22rpx;
  color: var(--gray-400);
}

/* File Info */
.file-info {
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 20rpx;
  background: var(--primary-bg);
  border-radius: 12rpx;
  border: 2rpx solid rgba(99, 102, 241, 0.2);
}

.file-icon {
  font-size: 40rpx;
}

.file-detail {
  flex: 1;
  min-width: 0;
}

.file-name {
  font-size: 26rpx;
  font-weight: 600;
  color: var(--gray-700);
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.file-size {
  font-size: 22rpx;
  color: var(--gray-400);
}

.file-remove {
  width: 48rpx;
  height: 48rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  color: var(--gray-400);
  font-size: 28rpx;
  border-radius: 50%;
  background: var(--gray-100);
}

/* Result */
.result-card {
  text-align: center;
}

.result-success {
  border: 2rpx solid rgba(16, 185, 129, 0.2);
  background: var(--success-bg);
}

.result-error {
  border: 2rpx solid rgba(239, 68, 68, 0.2);
  background: var(--danger-bg);
}

.result-icon {
  font-size: 48rpx;
  margin-bottom: 12rpx;
}

.result-message {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--gray-700);
  margin-bottom: 8rpx;
}

.result-detail {
  font-size: 24rpx;
  color: var(--gray-500);
}

.result-errors {
  text-align: left;
  margin-top: 16rpx;
  padding-top: 16rpx;
  border-top: 1rpx solid rgba(239, 68, 68, 0.15);
}

.errors-title {
  font-size: 24rpx;
  font-weight: 600;
  color: var(--danger);
  margin-bottom: 8rpx;
}

.error-item {
  font-size: 22rpx;
  color: var(--gray-600);
  padding: 4rpx 0;
}
