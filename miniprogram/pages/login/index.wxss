.login-page {
  min-height: 100vh;
  position: relative;
  overflow: hidden;
}

.bg-gradient {
  position: fixed;
  top: 0; left: 0; right: 0; bottom: 0;
  background: linear-gradient(135deg, #e0e7ff 0%, #ede9fe 30%, #dbeafe 60%, #e0f2fe 100%);
  z-index: -1;
}

.brand-section {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding-top: 180rpx;
  margin-bottom: 60rpx;
}

.brand-icon {
  font-size: 80rpx;
  margin-bottom: 16rpx;
}

.brand-title {
  font-size: 44rpx;
  font-weight: 800;
  color: var(--gray-800);
  letter-spacing: 2rpx;
}

.brand-subtitle {
  font-size: 24rpx;
  color: var(--gray-400);
  margin-top: 8rpx;
}

.form-card {
  margin: 0 40rpx;
  background: rgba(255, 255, 255, 0.95);
  border-radius: 24rpx;
  box-shadow: 0 8rpx 40rpx rgba(99, 102, 241, 0.12);
  padding: 0 36rpx 48rpx;
  backdrop-filter: blur(20px);
}

.auth-tabs {
  display: flex;
  border-bottom: 1rpx solid var(--gray-100);
  margin-bottom: 36rpx;
}

.auth-tab {
  flex: 1;
  text-align: center;
  padding: 28rpx 0;
  font-size: 30rpx;
  font-weight: 600;
  color: var(--gray-400);
  position: relative;
  transition: color 0.2s;
}

.auth-tab.active {
  color: var(--primary);
}

.auth-tab.active::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 30%;
  right: 30%;
  height: 4rpx;
  background: var(--primary);
  border-radius: 4rpx;
}

.form-body {
  padding-top: 8rpx;
}

.form-group {
  margin-bottom: 24rpx;
}

.input-wrap {
  background: var(--gray-50);
  border: 2rpx solid var(--gray-200);
  border-radius: 12rpx;
  padding: 20rpx 24rpx;
}

.input-field {
  font-size: 28rpx;
  color: var(--gray-800);
}

.error-msg {
  color: var(--danger);
  font-size: 24rpx;
  margin-bottom: 20rpx;
  text-align: center;
}

.login-btn {
  margin-top: 16rpx;
  height: 88rpx;
  font-size: 30rpx;
  border-radius: 12rpx;
}
